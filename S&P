<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8">
    <title>S&P 500 出貨日偵測 - 終極穩定版</title>
    <style>
        :root { --bg: #0b1220; --card: #111b33; --text: #e8f0ff; --ok: #38d39f; --danger: #ff4d4d; --warn: #ffcc33; }
        body { background: var(--bg); color: var(--text); font-family: sans-serif; padding: 20px; }
        .card { background: var(--card); border-radius: 12px; padding: 25px; border: 1px solid #233052; max-width: 900px; margin: auto; }
        button { background: var(--ok); color: #0b1220; font-weight: bold; cursor: pointer; border: none; padding: 12px; border-radius: 8px; width: 100%; margin-top: 10px; }
        table { width: 100%; margin-top: 20px; border-collapse: collapse; }
        th, td { padding: 12px; text-align: left; border-bottom: 1px solid #233052; font-size: 13px; }
        .tag { padding: 2px 6px; border-radius: 4px; font-size: 11px; font-weight: bold; color: #000; }
    </style>
</head>
<body>

<div class="card">
    <h2>🛡️ 出貨日偵測 (Google 轉接版)</h2>
    <p style="font-size: 12px; color: #9fb0d0;">解決 CORS 限制，100% 穩定抓取數據。</p>
    <input type="text" id="symbol" value="^SPX" style="width: 100%; padding: 10px; background: #0b1220; color: white; border: 1px solid #233052; border-radius: 8px; box-sizing: border-box;">
    <button onclick="fetchData()">執行分析</button>
    <p id="status" style="text-align:center; font-size:13px; margin-top:10px; color:var(--warn);"></p>
</div>

<table id="resultTable">
    <thead>
        <tr><th>日期</th><th>收盤價</th><th>漲跌幅</th><th>成交量</th><th>訊號判定</th></tr>
    </thead>
    <tbody id="tbody"></tbody>
</table>

<script>
    async function fetchData() {
        const scriptUrl = "YOUR_GOOGLE_SCRIPT_URL"; // 👈 貼上你的 Google Script 網址
        const sym = document.getElementById('symbol').value;
        const status = document.getElementById('status');
        const tbody = document.getElementById('tbody');

        if(scriptUrl === "YOUR_GOOGLE_SCRIPT_URL") return alert("請先在代碼中貼上你的 Google Script URL");

        status.innerText = "⚡ 正在透過 Google 伺服器獲取 Stooq 數據...";
        tbody.innerHTML = "";

        try {
            const resp = await fetch(`${scriptUrl}?s=${encodeURIComponent(sym)}`);
            const csvText = await resp.text();
            const lines = csvText.trim().split('\n');
            const data = lines.slice(1).reverse();

            let html = "";
            let distCount = 0;

            for (let i = 0; i < Math.min(data.length - 1, 40); i++) {
                const current = data[i].split(',');
                const prev = data[i+1].split(',');

                const date = current[0];
                const close = parseFloat(current[4]);
                const prevClose = parseFloat(prev[4]);
                const vol = parseInt(current[5]);
                const prevVol = parseInt(prev[5]);
                
                if (isNaN(close) || isNaN(vol)) continue;

                const change = ((close - prevClose) / prevClose) * 100;
                let signal = "";
                if (change < -0.2 && vol > prevVol) {
                    signal = '<span class="tag" style="background:var(--warn)">出貨日</span>';
                    distCount++;
                }

                html += `<tr><td>${date}</td><td>${close.toFixed(2)}</td><td style="color:${change < 0 ? 'var(--danger)' : 'var(--ok)'}">${change.toFixed(2)}%</td><td>${(vol/1000000).toFixed(2)}M</td><td>${signal}</td></tr>`;
            }

            tbody.innerHTML = html;
            status.innerText = `✅ 分析完成！共偵測到 ${distCount} 個訊號。`;
        } catch (e) {
            status.innerText = "❌ 發生錯誤，請確認 Google Script 是否部署正確。";
        }
    }
</script>
</body>
</html>
